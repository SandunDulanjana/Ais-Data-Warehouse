                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT
    dest_cluster                AS DestinationName,
    dest_cluster                AS PortName,
    'Unknown'                   AS Country,
    'Unknown'                   AS Region
FROM dbo.StgVesselTracking
WHERE dest_cluster IS NOT NULL
